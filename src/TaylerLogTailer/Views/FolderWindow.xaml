<Window x:Class="TaylerLogTailer.Views.FolderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tayler Log Tailer"
        Icon="/Assets/app.ico"
        Width="1000" Height="640"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        FontSize="12">

    <Window.Resources>
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Margin" Value="2,0,0,0" />
            <Setter Property="MinWidth" Value="0" />
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                Background="#FFF3F3F3"
                BorderBrush="#FFD0D0D0"
                BorderThickness="0,0,0,1"
                Padding="4,3">
            <DockPanel LastChildFill="True">
                <Button x:Name="FolderButton" DockPanel.Dock="Left" Style="{StaticResource ToolButton}"
                        Margin="0,0,0,0" Content="📁 Folder…" Click="OnChooseFolder"
                        ToolTip="Choose the folder of log files to tail" />

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Margin="8,0,2,0" Text="Pattern:" />
                    <TextBox x:Name="PatternBox" VerticalAlignment="Center"
                             Width="110" Text="*.log"
                             ToolTip="One or more glob patterns separated by ';' (e.g. *.log;*.txt)" />

                    <TextBlock VerticalAlignment="Center" Margin="8,0,2,0" Text="Lines:" />
                    <TextBox x:Name="LinesBox" VerticalAlignment="Center"
                             Width="44" Text="0"
                             ToolTip="Number of existing lines to show from each file (0 = only new lines)" />

                    <CheckBox x:Name="RecursiveCheck" VerticalAlignment="Center"
                              Margin="8,0,0,0" Content="Subfolders" />
                    <CheckBox x:Name="AutoScrollCheck" VerticalAlignment="Center"
                              Margin="8,0,0,0" Content="Auto-scroll" IsChecked="True" />

                    <Button x:Name="ApplyButton" Style="{StaticResource ToolButton}"
                            Margin="8,0,0,0" Content="Apply" Click="OnApply"
                            ToolTip="Apply the pattern / options and restart tailing" />
                    <Button x:Name="PauseButton" Style="{StaticResource ToolButton}"
                            Content="Pause" Click="OnTogglePause"
                            ToolTip="Pause or resume following the log files" />
                    <Button x:Name="ClearButton" Style="{StaticResource ToolButton}"
                            Content="Clear" Click="OnClear"
                            ToolTip="Clear the current view (does not change the files)" />
                    <Button x:Name="ForgetButton" Style="{StaticResource ToolButton}"
                            Content="Forget" Click="OnForget"
                            ToolTip="Close this window and stop reopening this folder on next run" />
                    <Button x:Name="NewWindowButton" Style="{StaticResource ToolButton}"
                            Content="New Window" Click="OnNewWindow"
                            ToolTip="Open another window for a different folder" />
                </StackPanel>

                <TextBox x:Name="FolderText" VerticalAlignment="Center" Margin="6,0"
                         IsReadOnly="True" Background="Transparent" BorderThickness="0"
                         Foreground="#FF505050" />
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="#FFF3F3F3"
                BorderBrush="#FFD0D0D0"
                BorderThickness="0,1,0,0"
                Padding="6,2">
            <TextBlock x:Name="StatusText" FontSize="11" Foreground="#FF505050" Text="No folder selected." />
        </Border>

        <!-- Combined log view -->
        <Grid Background="White">
            <Image Source="/Assets/watermark.png" Stretch="Uniform"
                   Width="380" Opacity="0.08"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   IsHitTestVisible="False" />
            <DataGrid x:Name="LogGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      HeadersVisibility="Column"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      GridLinesVisibility="None"
                      Background="Transparent"
                      RowBackground="Transparent"
                      AlternatingRowBackground="#0A000000"
                      RowHeight="17"
                      ColumnHeaderHeight="20"
                      FontFamily="Consolas"
                      FontSize="12"
                      BorderThickness="0"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="False">
                <DataGrid.Resources>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="4,0" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Padding" Value="4,1" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="File" Binding="{Binding FileName}"
                                        Width="Auto" MinWidth="90" />
                    <DataGridTextColumn Header="Log" Binding="{Binding Text}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </DockPanel>
</Window>
